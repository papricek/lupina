#!/usr/bin/env ruby
# Build wattlink/tmp/learning_consumption_V1.xlsx — 20 customer EANs (mostly big,
# some middle, few small) with measured aggregates and two descriptions per
# entry (POPIS LAIK = casual layperson, POPIS ZKUŠENÝ = technical with numbers).
#
# Run inside wattlink env:
#   chruby-exec ruby-3.2.2 -- bin/rails runner /Users/patrikjira/Work/claude/lupina/eval/bin/build-consumption-xlsx

require "caxlsx"

OUTFILE = "/Users/patrikjira/Work/wattlink/tmp/learning_consumption_V1.xlsx"

# 12 big + 6 middle + 2 small = 20
SELECTED = [
  # ───── BIG (12): >64 MWh total measured ─────
  "859182400200010071",  # 1475 MWh, Zlín — likely heavy industry, 24/7
  "859182400200001581",  #  653 MWh
  "859182403010002113",  #  538 MWh
  "859182400200064821",  #  502 MWh, Zlín
  "859182403010001918",  #  432 MWh
  "859182400200044137",  #  303 MWh
  "859182403010000775",  #  300 MWh
  "859182400200051982",  #  246 MWh, Zlín
  "859182400211437324",  #  129 MWh, Brumovice — 46k readings (very long history)
  "859182401370002033",  #  121 MWh, Mor. Ostrava
  "859182400509516298",  #   94 MWh, Přerov
  "859182400405886150",  #   90 MWh, Česká Lípa
  # ───── MIDDLE (6): 5-64 MWh total ─────
  "859182401960000807",  # 60 MWh, Zlín
  "859182400200841071",  # 55 MWh, Třebíč
  "859182400200901515",  # 51 MWh, Žďár nad Sázavou
  "859182400500246484",  # 41 MWh, Frýdek-Místek
  "859182400700067650",  # 24 MWh
  "859182400110256750",  # 11 MWh, Strakonice
  # ───── SMALL (2): <5 MWh total ─────
  "859182400100367800",  # 4.8 MWh, Pelhřimov
  "859182400700516929"   # 1.3 MWh, Okres Ústí nad Orlicí
].freeze

CZECH_WEEKDAYS = %w[Po Út St Čt Pá So Ne].freeze
CZECH_MONTHS = %w[leden únor březen duben květen červen červenec srpen září říjen listopad prosinec].freeze

def address_label(ean)
  addr = Address.find_by(ean: ean)
  return "EAN #{ean[-6..]}" unless addr
  parts = []
  parts << addr.account.name if addr.respond_to?(:account) && addr.account
  if addr.geocoding.is_a?(Hash)
    parts << (addr.geocoding["city"] || addr.geocoding["town"] || addr.geocoding["village"])
  end
  parts.compact.reject(&:empty?).first(2).join(", ").presence || "EAN #{ean[-6..]}"
end

def compute_aggregates(ean)
  rows = ActiveRecord::Base.connection.exec_query(
    ActiveRecord::Base.sanitize_sql_array([
      "SELECT shared_at, original FROM edc_readings WHERE ean = ? ORDER BY shared_at", ean
    ])
  ).to_a

  rows.each { |r| r["shared_at"] = r["shared_at"].is_a?(String) ? Time.zone.parse(r["shared_at"]) : r["shared_at"].in_time_zone("Europe/Prague") }

  return nil if rows.empty?

  per_hour_wd = Array.new(24, 0.0); per_hour_wd_n = Array.new(24, 0)
  per_hour_we = Array.new(24, 0.0); per_hour_we_n = Array.new(24, 0)
  monthly = Hash.new(0.0)
  per_weekday_total = Hash.new(0.0); per_weekday_n = Hash.new(0)
  per_15min_max = 0.0
  total = 0.0

  rows.each do |r|
    val = r["original"].to_f.abs
    total += val
    per_15min_max = val if val > per_15min_max
    h = r["shared_at"].hour
    wday = r["shared_at"].wday
    if wday == 0 || wday == 6
      per_hour_we[h] += val; per_hour_we_n[h] += 1
    else
      per_hour_wd[h] += val; per_hour_wd_n[h] += 1
    end
    per_weekday_total[wday] += val
    per_weekday_n[wday] += 1
    month_key = r["shared_at"].strftime("%Y-%m")
    monthly[month_key] += val
  end

  workday_avg = per_hour_wd.each_with_index.map { |s, i| per_hour_wd_n[i] > 0 ? s / per_hour_wd_n[i] * 4 : 0.0 }
  weekend_avg = per_hour_we.each_with_index.map { |s, i| per_hour_we_n[i] > 0 ? s / per_hour_we_n[i] * 4 : 0.0 }

  workday_total = (1..5).sum { |d| per_weekday_total[d] }
  weekend_total = [ 0, 6 ].sum { |d| per_weekday_total[d] }
  workday_n = (1..5).sum { |d| per_weekday_n[d] }
  weekend_n = [ 0, 6 ].sum { |d| per_weekday_n[d] }
  workday_daily = workday_n > 0 ? workday_total / (workday_n / 96.0) : 0
  weekend_daily = weekend_n > 0 ? weekend_total / (weekend_n / 96.0) : 0

  baseline_kw = workday_avg.min  # off-peak draw, 15min avg in kW

  duration_days = ((rows.last["shared_at"] - rows.first["shared_at"]) / 86400.0)

  # Yearly extrapolation
  yearly_kwh = total / [ duration_days, 1 ].max * 365

  {
    rows: rows.size,
    total_kwh: total,
    yearly_kwh: yearly_kwh,
    yearly_mwh: yearly_kwh / 1000.0,
    workday_hourly_avg_kw: workday_avg,
    weekend_hourly_avg_kw: weekend_avg,
    workday_daily_kwh: workday_daily,
    weekend_daily_kwh: weekend_daily,
    workday_peak_hour: workday_avg.each_with_index.max_by { |v, _| v }[1],
    weekend_peak_hour: weekend_avg.each_with_index.max_by { |v, _| v }[1],
    workday_peak_kw: workday_avg.max,
    weekend_peak_kw: weekend_avg.max,
    baseline_kw: baseline_kw,
    peak_15min_kwh: per_15min_max,
    peak_kw: per_15min_max * 4,
    monthly_totals: monthly.sort.to_h,
    duration_days: duration_days.round(0),
    we_wd_ratio: workday_daily > 0 ? (weekend_daily / workday_daily).round(2) : nil
  }
end

def build_aggregate_summary(agg)
  active_hours = agg[:workday_hourly_avg_kw].each_with_index
                                            .select { |v, _| v > agg[:workday_peak_kw] * 0.30 }
                                            .map(&:last)
  active_range = active_hours.empty? ? "—" : "#{active_hours.min}-#{active_hours.max}"

  monthly_str = agg[:monthly_totals].map { |k, v| "#{k}: #{v.round(0)}" }.first(12).join(", ")
  baseline_pct = agg[:workday_peak_kw] > 0 ? (agg[:baseline_kw] / agg[:workday_peak_kw] * 100).round(0) : 0

  <<~TXT
    Měsíční úhrny (kWh):           #{monthly_str}
    Celkem za #{agg[:duration_days]} dní:        #{agg[:total_kwh].round(0)} kWh (extrapolace ročně: #{agg[:yearly_mwh].round(1)} MWh)
    Průměrný všední den:           #{agg[:workday_daily_kwh].round(0)} kWh
    Průměrný víkendový den:        #{agg[:weekend_daily_kwh].round(0)} kWh (víkend/všední = #{agg[:we_wd_ratio]})
    Špička 15min:                  #{agg[:peak_kw].round(1)} kW
    Aktivní okno (workday >30 % peak): #{active_range}
    Workday peak hodina:           #{agg[:workday_peak_hour]}:00 (#{agg[:workday_peak_kw].round(1)} kW průměr)
    Weekend peak hodina:           #{agg[:weekend_peak_hour]}:00 (#{agg[:weekend_peak_kw].round(1)} kW průměr)
    Bazální spotřeba (off-peak):  #{agg[:baseline_kw].round(2)} kW (#{baseline_pct}% peaku)
    Workday hodinový profil (kW):  #{agg[:workday_hourly_avg_kw].each_with_index.map { |v, h| "#{h}h:#{v.round(1)}" }.join(" ")}
    Weekend hodinový profil (kW):  #{agg[:weekend_hourly_avg_kw].each_with_index.map { |v, h| "#{h}h:#{v.round(1)}" }.join(" ")}
  TXT
end

def generate_descriptions(label, agg)
  summary = build_aggregate_summary(agg)
  prompt = <<~PROMPT
    Jsi expert na české odběratele elektřiny. Pro odběrné místo "#{label}" mám reálná měření spotřeby:

    #{summary}

    Tvůj úkol: Napiš DVA české popisy charakteru spotřeby tohoto odběrného místa, oba MUSÍ věrně odrážet
    výše uvedené reálné měření (denní profil, víkend vs. všední, sezónnost, baseline, peak hodina).

    1) "POPIS LAIK" — krátký, neformální popis, 2-3 věty, jak by to popsal majitel/uživatel sám sobě.
       Žádná konkrétní čísla v kWh/kW, jen obecné výrazy ("hlavně přes den", "v noci skoro nic",
       "v zimě výrazně víc", "víkend je klid" apod.).

    2) "POPIS ZKUŠENÝ" — odbornější popis 3-5 vět s konkrétními čísly: roční MWh nebo měsíční kWh,
       špička v daný čas, denní průměr všední/víkendový, sezónnost, peak v hodinu X-Y. Cíl: aby
       z popisu šlo přesně rekonstruovat hodinový profil ±15 %.

    Vrať POUZE validní JSON, bez markdownu, bez komentářů:
    {
      "popis_laik": "...",
      "popis_zkuseny": "..."
    }
  PROMPT

  chat = RubyLLM.chat(model: Lupina.configuration.model).with_temperature(0.3)
  resp = chat.ask(prompt)
  text = resp.content
  text = $1.strip if text =~ /```(?:json)?\s*\n?(.*?)\n?\s*```/m
  JSON.parse(text)
rescue => e
  warn "  description gen failed: #{e.class}: #{e.message}"
  { "popis_laik" => "", "popis_zkuseny" => "" }
end

# ───────── main ─────────

results = []
SELECTED.each_with_index do |ean, i|
  print "  [#{i + 1}/#{SELECTED.size}] EAN #{ean[-6..]}  "
  agg = compute_aggregates(ean)
  unless agg
    puts "no data, skipping"
    next
  end
  print "agg ✓  "
  label = address_label(ean)
  print "label '#{label[0, 24]}'  "
  descs = generate_descriptions(label, agg)
  puts "descs ✓"
  results << { ean: ean, label: label, agg: agg, descs: descs }
end

puts "\nWriting xlsx with #{results.size} entries..."
Axlsx::Package.new do |p|
  p.workbook.add_worksheet(name: "Consumption V1") do |sheet|
    sheet.add_row [ "FIRMA", "EAN", "Spotřeba (MWh/rok)", "POPIS LAIK", "POPIS ZKUŠENÝ" ]
    results.each do |r|
      sheet.add_row [
        r[:label],
        r[:ean],
        r[:agg][:yearly_mwh].round(1),
        r[:descs]["popis_laik"],
        r[:descs]["popis_zkuseny"]
      ]
    end
    sheet.column_widths 24, 22, 14, 60, 80
  end
  p.serialize(OUTFILE)
end

puts "Saved → #{OUTFILE}"
puts "Entries: #{results.size}"
